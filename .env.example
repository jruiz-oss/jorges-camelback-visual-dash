# Copy this file to .env.local for local dev, then add to Vercel Environment Variables

# --- Dashboard password (anything you want) ---
DASHBOARD_PASSWORD=yourpasswordhere

# --- Meta Ads ---
META_ACCESS_TOKEN=your_long_lived_access_token
META_AD_ACCOUNT_ID=act_123456789

# --- Google Ads ---
GOOGLE_DEVELOPER_TOKEN=your_developer_token
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REFRESH_TOKEN=your_refresh_token
GOOGLE_CUSTOMER_ID=1234567890
GOOGLE_LOGIN_CUSTOMER_ID=    # MCC account ID if applicable, else leave blank

# --- StackAdapt ---
STACKADAPT_API_KEY=your_api_key
